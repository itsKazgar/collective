# ── point Python at the BR0THA_bot folder so imports work ─────────────────────
BOT_DIR = Path(__file__).parent
sys.path.insert(0, str(BOT_DIR))

from fastapi import FastAPI, HTTPException
from fastapi.middleware.cors import CORSMiddleware
from fastapi.responses import JSONResponse
from pydantic import BaseModel
from typing import Optional
from dotenv import load_dotenv

load_dotenv(BOT_DIR / ".env", override=True)

# ── lazy imports from your bot ─────────────────────────────────────────────────
try:
    from agent_personas import COUNCIL_CONFIG, PERSONAS, get_agent_list, get_weight
    PERSONAS_OK = True
except Exception as e:
    PERSONAS_OK = False
    print(f"[WARN] agent_personas import failed: {e}")

try:
    from paper_trader import (
        get_portfolio, get_open_positions, init_paper_db,
        open_position, check_positions,
    )
    PAPER_OK = True
except Exception as e:
    PAPER_OK = False
    print(f"[WARN] paper_trader import failed: {e}")

DB_PATH  = BOT_DIR / "data" / "agent.db"
ENV_PATH = BOT_DIR / ".env"

app = FastAPI(title="BR0THA API", version="1.0")

# allow dashboard HTML (served from any origin / file://) to call this
app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_methods=["*"],
    allow_headers=["*"],
)

# ── bot process handle ─────────────────────────────────────────────────────────
_bot_process: Optional[subprocess.Popen] = None


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  HELPERS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

def db():
    return sqlite3.connect(DB_PATH)

def read_env() -> dict:
    """Read .env into a dict (keys only, values masked)."""
    keys = {}
    if ENV_PATH.exists():
        for line in ENV_PATH.read_text().splitlines():
            line = line.strip()
            if line and not line.startswith("#") and "=" in line:
                k, v = line.split("=", 1)
                keys[k.strip()] = bool(v.strip())
    return keys

def write_env_key(key: str, value: str):
    """Write or update a single key in .env"""
    lines = []
    found = False
    if ENV_PATH.exists():
        for line in ENV_PATH.read_text().splitlines():
            if line.strip().startswith(f"{key}="):
                lines.append(f"{key}={value}")
                found = True
            else:
                lines.append(line)
    if not found:
        lines.append(f"{key}={value}")
    ENV_PATH.write_text("\n".join(lines) + "\n")

def fear_and_greed() -> dict:
    import requests as req
    try:
        r = req.get("https://api.alternative.me/fng/?limit=1", timeout=5)
        d = r.json()["data"][0]
        return {"value": int(d["value"]), "label": d["value_classification"]}
    except:
        return {"value": 50, "label": "Neutral"}

def bot_running() -> bool:
    global _bot_process
    if _bot_process and _bot_process.poll() is None:
        return True
    # also check if loop.py is running externally
    try:
        import psutil
        for proc in psutil.process_iter(["cmdline"]):
            cmdline = " ".join(proc.info["cmdline"] or [])
            if "loop.py" in cmdline or "telegram_bot.py" in cmdline:
                return True
    except:
        pass
    return False


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  STATUS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

@app.get("/status")
def get_status():
    """Bot running state + Fear & Greed index."""
    fg = fear_and_greed()
    return {
        "running":      bot_running(),
        "fear_greed":   fg["value"],
        "fg_label":     fg["label"],
        "paper_trading": COUNCIL_CONFIG.get("paper_trading", True) if PERSONAS_OK else True,
        "ts":           datetime.utcnow().isoformat(),
    }


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  PORTFOLIO
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

@app.get("/portfolio")
def get_portfolio_data():
    """Cash, open positions, closed trade PnL, win rate."""
    try:
        cash = get_portfolio() if PAPER_OK else 1000.0
    except:
        cash = 1000.0

    positions = []
    realized_pnl = 0.0
    wins = losses = 0

    try:
        with db() as conn:
            # open positions
            rows = conn.execute(
                "SELECT token, mint, entry_price, current_price, size_usd, "
                "tokens_held, tp_price, sl_price, pnl_pct, opened_at "
                "FROM positions WHERE status='OPEN'"
            ).fetchall()
            for r in rows:
                positions.append({
                    "token":       r[0], "mint":      r[1],
                    "entry_price": r[2], "current":   r[3],
                    "size_usd":    r[4], "tokens":    r[5],
                    "tp_price":    r[6], "sl_price":  r[7],
                    "pnl_pct":     r[8], "opened_at": r[9],
                })

            # closed trades PnL
            closed = conn.execute(
                "SELECT SUM(pnl_usd), COUNT(*) FROM positions WHERE status='CLOSED'"
            ).fetchone()
            realized_pnl = round(closed[0] or 0, 2)

            wins = conn.execute(
                "SELECT COUNT(*) FROM positions WHERE status='CLOSED' AND pnl_usd > 0"
            ).fetchone()[0]
            losses = conn.execute(
                "SELECT COUNT(*) FROM positions WHERE status='CLOSED' AND pnl_usd <= 0"
            ).fetchone()[0]
    except Exception as e:
        print(f"[portfolio] DB error: {e}")

    total_closed = wins + losses
    win_rate = round((wins / max(total_closed, 1)) * 100, 1)

    return {
        "cash":         round(cash, 2),
        "portfolio":    round(cash + realized_pnl, 2),
        "realized_pnl": realized_pnl,
        "win_rate":     win_rate,
        "wins":         wins,
        "losses":       losses,
        "positions":    positions,
    }


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  TRADES
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

@app.get("/trades")
def get_trades(limit: int = 20):
    """Recent trade log."""
    try:
        with db() as conn:
            rows = conn.execute(
                "SELECT token, action, price, size_usd, pnl_usd, pnl_pct, reason, timestamp "
                "FROM trade_log ORDER BY timestamp DESC LIMIT ?",
                (limit,)
            ).fetchall()
        return [
            {
                "token":   r[0], "action": r[1], "price":   r[2],
                "size":    r[3], "pnl":    r[4], "pnl_pct": r[5],
                "reason":  r[6], "ts":     r[7],
            }
            for r in rows
        ]
    except Exception as e:
        return []


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  AGENTS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

@app.get("/agents")
def get_agents():
    """Return live agent list from agent_personas.py + council config."""
    if not PERSONAS_OK:
        return {"agents": [], "config": {}}

    agents = []
    for key, persona in PERSONAS.items():
        if key == "orchestrator":
            continue
        agents.append({
            "id":     key,
            "name":   persona["name"],
            "model":  persona["model"],
            "role":   persona["role"],
            "weight": COUNCIL_CONFIG["weights"].get(key, 1),
            "active": True,
        })

    return {
        "agents": agents,
        "config": {
            "vote_threshold":    COUNCIL_CONFIG["vote_threshold"],
            "min_agents_trade":  COUNCIL_CONFIG["min_agents_trade"],
            "paper_trading":     COUNCIL_CONFIG["paper_trading"],
            "take_profit_pct":   COUNCIL_CONFIG["take_profit_pct"],
            "stop_loss_pct":     COUNCIL_CONFIG["sl_target"],
            "max_position_pct":  COUNCIL_CONFIG["max_position_pct"],
        },
    }


class AgentUpdate(BaseModel):
    name:   Optional[str] = None
    model:  Optional[str] = None
    weight: Optional[int] = None
    active: Optional[bool] = None

@app.patch("/agents/{agent_id}")
def update_agent(agent_id: str, body: AgentUpdate):
    """Update an agent's model or weight. Writes back to agent_personas.py config."""
    if not PERSONAS_OK:
        raise HTTPException(500, "agent_personas not loaded")
    if agent_id not in PERSONAS and agent_id != "orchestrator":
        raise HTTPException(404, f"Agent {agent_id} not found")
    if body.weight is not None:
        COUNCIL_CONFIG["weights"][agent_id] = body.weight
    if body.model is not None:
        PERSONAS[agent_id]["model"] = body.model
    return {"ok": True, "agent": agent_id}


class NewAgent(BaseModel):
    id:     str
    name:   str
    model:  str
    role:   str = "Custom Agent"
    weight: int = 1

@app.post("/agents")
def add_agent(body: NewAgent):
    """Add a new agent to the council at runtime."""
    if not PERSONAS_OK:
        raise HTTPException(500, "agent_personas not loaded")
    PERSONAS[body.id] = {
        "model":  body.model,
        "name":   body.name,
        "role":   body.role,
        "system": f"You are {body.name}, a custom council agent. Be concise and data-driven.",
    }
    COUNCIL_CONFIG["weights"][body.id] = body.weight
    return {"ok": True, "agent": body.id}

@app.delete("/agents/{agent_id}")
def remove_agent(agent_id: str):
    if not PERSONAS_OK:
        raise HTTPException(500, "agent_personas not loaded")
    if agent_id in ("orchestrator", "risk", "security"):
        raise HTTPException(400, "Cannot remove core agents")
    PERSONAS.pop(agent_id, None)
    COUNCIL_CONFIG["weights"].pop(agent_id, None)
    return {"ok": True}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  API KEYS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

TRACKED_KEYS = [
    "HELIUS_API_KEY", "BIRDEYE_API_KEY", "GROQ_API_KEY",
    "CEREBRAS_API_KEY", "SOLTRACKER_API_KEY", "OPENROUTER_API_KEY",
    "TELEGRAM_TOKEN", "BIRDEYE_API_KEY",
]

@app.get("/keys")
def get_keys():
    """Return which keys are set (never return actual values)."""
    result = {}
    for k in TRACKED_KEYS:
        val = os.getenv(k, "")
        result[k] = {"set": bool(val), "preview": (val[:4] + "****") if val else ""}
    return result


class KeyUpdate(BaseModel):
    key:   str
    value: str

@app.post("/keys")
def save_key(body: KeyUpdate):
    """Save an API key to .env and reload into env."""
    if body.key not in TRACKED_KEYS:
        raise HTTPException(400, f"Unknown key: {body.key}")
    write_env_key(body.key, body.value)
    os.environ[body.key] = body.value
    load_dotenv(ENV_PATH, override=True)
    return {"ok": True, "key": body.key}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  SETTINGS
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

class SettingsUpdate(BaseModel):
    paper_trading:    Optional[bool]  = None
    vote_threshold:   Optional[int]   = None
    min_agents_trade: Optional[int]   = None
    take_profit_pct:  Optional[float] = None
    stop_loss_pct:    Optional[float] = None
    max_position_pct: Optional[float] = None

@app.get("/settings")
def get_settings():
    if not PERSONAS_OK:
        return {}
    return {
        "paper_trading":    COUNCIL_CONFIG["paper_trading"],
        "vote_threshold":   COUNCIL_CONFIG["vote_threshold"],
        "min_agents_trade": COUNCIL_CONFIG["min_agents_trade"],
        "take_profit_pct":  COUNCIL_CONFIG["take_profit_pct"],
        "stop_loss_pct":    COUNCIL_CONFIG["sl_target"],
        "max_position_pct": COUNCIL_CONFIG["max_position_pct"],
        "moon_bag_pct":     COUNCIL_CONFIG["moon_bag_pct"],
    }

@app.patch("/settings")
def update_settings(body: SettingsUpdate):
    if not PERSONAS_OK:
        raise HTTPException(500, "agent_personas not loaded")
    if body.paper_trading    is not None: COUNCIL_CONFIG["paper_trading"]    = body.paper_trading
    if body.vote_threshold   is not None: COUNCIL_CONFIG["vote_threshold"]   = body.vote_threshold
    if body.min_agents_trade is not None: COUNCIL_CONFIG["min_agents_trade"] = body.min_agents_trade
    if body.take_profit_pct  is not None: COUNCIL_CONFIG["take_profit_pct"]  = body.take_profit_pct
    if body.stop_loss_pct    is not None: COUNCIL_CONFIG["sl_target"]        = body.stop_loss_pct
    if body.max_position_pct is not None: COUNCIL_CONFIG["max_position_pct"] = body.max_position_pct
    return {"ok": True}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  BOT CONTROL
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

@app.post("/bot/start")
def start_bot():
    global _bot_process
    if bot_running():
        return {"ok": False, "msg": "Bot already running"}
    loop_path = BOT_DIR / "loop.py"
    if not loop_path.exists():
        return {"ok": False, "msg": "loop.py not found"}
    _bot_process = subprocess.Popen(
        [sys.executable, str(loop_path)],
        cwd=str(BOT_DIR),
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )
    return {"ok": True, "pid": _bot_process.pid}

@app.post("/bot/stop")
def stop_bot():
    global _bot_process
    if _bot_process and _bot_process.poll() is None:
        _bot_process.terminate()
        _bot_process = None
        return {"ok": True, "msg": "Bot stopped"}
    return {"ok": False, "msg": "Bot not running via API (may be running externally)"}


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  SCAN LOG / INTEL
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

@app.get("/scans")
def get_scan_log(limit: int = 10):
    try:
        with db() as conn:
            rows = conn.execute(
                "SELECT tokens_scanned, tokens_approved, top_token, timestamp "
                "FROM scan_log ORDER BY timestamp DESC LIMIT ?",
                (limit,)
            ).fetchall()
        return [{"scanned": r[0], "approved": r[1], "top": r[2], "ts": r[3]} for r in rows]
    except:
        return []

@app.get("/votes")
def get_vote_log(limit: int = 20):
    """Recent council votes."""
    try:
        with db() as conn:
            rows = conn.execute(
                "SELECT token, agent, decision, confidence, weight, timestamp "
                "FROM council_votes ORDER BY timestamp DESC LIMIT ?",
                (limit,)
            ).fetchall()
        return [
            {"token": r[0], "agent": r[1], "decision": r[2],
             "confidence": r[3], "weight": r[4], "ts": r[5]}
            for r in rows
        ]
    except:
        return []


# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  STARTUP
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

@app.on_event("startup")
def startup():
    os.makedirs(BOT_DIR / "data", exist_ok=True)
    if PAPER_OK:
        try:
            init_paper_db()
        except:
            pass
    print("BR0THA API running on http://0.0.0.0:8000")
    print("Docs at http://localhost:8000/docs")
