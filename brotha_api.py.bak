"""
brotha_api.py — BR0THA Dashboard API Server
Run: uvicorn brotha_api:app --host 0.0.0.0 --port 8000 --reload

Drop this file into ~/BR0THA_bot/ and run from within the venv.
It reads directly from your existing DB and imports your existing modules.
"""

import os, sys, sqlite3, json, time, subprocess, signal
