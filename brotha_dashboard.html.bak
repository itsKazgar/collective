<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BR0THA Dashboard</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@2.44.0/tabler-icons.min.css">
<style>
* { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --bg:       #0d0f14;
  --bg2:      #161920;
  --bg3:      #1e2130;
  --border:   #2a2e3f;
  --text:     #e2e4ef;
  --muted:    #7b8099;
  --green:    #22c55e;
  --red:      #ef4444;
  --yellow:   #f59e0b;
  --blue:     #6366f1;
  --radius:   8px;
  --font:     'SF Mono', 'Fira Code', monospace;
}
body { background: var(--bg); color: var(--text); font-family: var(--font); font-size: 13px; min-height: 100vh; }
.dash { padding: 16px; max-width: 900px; margin: 0 auto; }
.topbar { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
.topbar h1 { font-size: 15px; font-weight: 600; letter-spacing: 0.05em; color: var(--text); }
.topbar h1 span { color: var(--blue); }
.badge { font-size: 11px; padding: 3px 10px; border-radius: 20px; font-weight: 600; }
.badge.on  { background: rgba(34,197,94,.15); color: var(--green); border: 1px solid rgba(34,197,94,.3); }
.badge.off { background: rgba(239,68,68,.12); color: var(--red);   border: 1px solid rgba(239,68,68,.25); }
.btn { font-size: 12px; padding: 5px 12px; border-radius: var(--radius); border: 1px solid var(--border); background: var(--bg3); color: var(--muted); cursor: pointer; font-family: var(--font); transition: all .15s; }
.btn:hover { color: var(--text); border-color: var(--blue); }
.btn.danger { border-color: rgba(239,68,68,.4); color: var(--red); }
.btn.primary { border-color: rgba(99,102,241,.5); color: var(--blue); }
.metrics { display: grid; grid-template-columns: repeat(4,1fr); gap: 10px; margin-bottom: 18px; }
.metric { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 14px; }
.metric .label { font-size: 11px; color: var(--muted); margin-bottom: 6px; text-transform: uppercase; letter-spacing: .05em; }
.metric .value { font-size: 22px; font-weight: 700; }
.metric .value.green { color: var(--green); }
.metric .value.red   { color: var(--red); }
.fg-bar-wrap { display: flex; align-items: center; gap: 10px; background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 10px 14px; margin-bottom: 18px; }
.fg-bar { flex: 1; height: 5px; border-radius: 3px; background: var(--bg3); overflow: hidden; }
.fg-fill { height: 100%; border-radius: 3px; background: var(--yellow); transition: width .6s ease; }
.tabs { display: flex; gap: 6px; margin-bottom: 16px; border-bottom: 1px solid var(--border); padding-bottom: 10px; }
.tab { font-size: 12px; padding: 5px 14px; border-radius: 6px; border: 1px solid transparent; background: transparent; color: var(--muted); cursor: pointer; font-family: var(--font); transition: all .15s; }
.tab.active { background: var(--bg3); color: var(--text); border-color: var(--border); }
.panel { display: none; }
.panel.active { display: block; }
.grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
.card { background: var(--bg2); border: 1px solid var(--border); border-radius: var(--radius); padding: 16px; }
.card h3 { font-size: 10px; font-weight: 600; color: var(--muted); text-transform: uppercase; letter-spacing: .08em; margin-bottom: 12px; }
.agent-row, .trade-row, .api-row, .setting-row { display: flex; align-items: center; gap: 8px; padding: 7px 0; border-bottom: 1px solid var(--border); }
.agent-row:last-child, .trade-row:last-child, .api-row:last-child, .setting-row:last-child { border-bottom: none; }
.dot { width: 7px; height: 7px; border-radius: 50%; flex-shrink: 0; }
.dot.green  { background: var(--green); box-shadow: 0 0 6px var(--green); }
.dot.yellow { background: var(--yellow); }
.dot.red    { background: var(--red); }
.agent-name  { font-size: 12px; font-weight: 600; min-width: 80px; }
.agent-model { font-size: 11px; color: var(--muted); flex: 1; }
.agent-weight{ font-size: 11px; color: var(--muted); min-width: 30px; text-align: right; }
.side { font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 4px; text-transform: uppercase; }
.side.buy  { background: rgba(34,197,94,.15); color: var(--green); }
.side.sell { background: rgba(239,68,68,.12); color: var(--red); }
.pnl.pos { color: var(--green); font-weight: 600; margin-left: auto; }
.pnl.neg { color: var(--red);   font-weight: 600; margin-left: auto; }
.api-name { font-size: 12px; font-weight: 600; min-width: 110px; }
.api-input { flex: 1; font-size: 11px; font-family: var(--font); background: var(--bg3); border: 1px solid var(--border); border-radius: 6px; padding: 5px 8px; color: var(--text); outline: none; }
.api-input:focus { border-color: var(--blue); }
.status-pill { font-size: 10px; padding: 2px 8px; border-radius: 10px; font-weight: 600; white-space: nowrap; }
.status-pill.ok   { background: rgba(34,197,94,.12); color: var(--green); }
.status-pill.fail { background: rgba(239,68,68,.10); color: var(--red); }
.setting-label { flex: 1; }
.setting-label small { display: block; font-size: 10px; color: var(--muted); }
.setting-val { font-size: 12px; color: var(--muted); min-width: 60px; text-align: right; }
.toggle { width: 36px; height: 20px; border-radius: 10px; background: var(--bg3); border: 1px solid var(--border); position: relative; cursor: pointer; flex-shrink: 0; transition: background .2s; }
.toggle.on { background: rgba(34,197,94,.25); border-color: var(--green); }
.toggle::after { content:''; position:absolute; width:14px; height:14px; border-radius:50%; background:var(--muted); top:2px; left:3px; transition:left .15s; }
.toggle.on::after { left:19px; background:var(--green); }
.add-row { display: flex; gap: 8px; margin-top: 12px; }
.add-row input, .add-row select { font-size: 11px; padding: 5px 8px; border-radius: 6px; border: 1px solid var(--border); background: var(--bg3); color: var(--text); font-family: var(--font); outline: none; }
.add-row input { flex: 1; }
.empty { text-align: center; padding: 24px 0; color: var(--muted); font-size: 12px; }
.save-btn { font-size: 11px; padding: 4px 10px; border-radius: 6px; border: 1px solid rgba(99,102,241,.4); background: rgba(99,102,241,.1); color: var(--blue); cursor: pointer; font-family: var(--font); white-space: nowrap; }
.save-btn:hover { background: rgba(99,102,241,.2); }
.toast { position: fixed; bottom: 20px; right: 20px; background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 10px 16px; font-size: 12px; color: var(--text); opacity: 0; transition: opacity .2s; pointer-events: none; z-index: 999; }
.toast.show { opacity: 1; }
@media (max-width: 600px) { .metrics { grid-template-columns: 1fr 1fr; } .grid2 { grid-template-columns: 1fr; } }
</style>
</head>
<body>
<div class="dash">

  <div class="topbar">
    <h1><i class="ti ti-robot"></i> <span>BR0THA</span> DASHBOARD</h1>
    <div style="display:flex;align-items:center;gap:8px">
      <span id="bot-badge" class="badge off">stopped</span>
      <button class="btn danger" id="bot-btn" onclick="toggleBot()">start bot</button>
      <button class="btn" onclick="refreshAll()"><i class="ti ti-refresh"></i></button>
    </div>
  </div>

  <div class="metrics">
    <div class="metric">
      <div class="label">portfolio</div>
      <div class="value" id="m-portfolio">$—</div>
    </div>
    <div class="metric">
      <div class="label">total pnl</div>
      <div class="value" id="m-pnl">—</div>
    </div>
    <div class="metric">
      <div class="label">win rate</div>
      <div class="value" id="m-winrate">—</div>
    </div>
    <div class="metric">
      <div class="label">open positions</div>
      <div class="value" id="m-positions">—</div>
    </div>
  </div>

  <div class="fg-bar-wrap">
    <i class="ti ti-mood-nervous" style="color:var(--yellow)"></i>
    <span style="color:var(--muted)">fear & greed</span>
    <div class="fg-bar"><div class="fg-fill" id="fg-fill" style="width:50%"></div></div>
    <span id="fg-label" style="font-weight:600;color:var(--yellow)">50 — Neutral</span>
  </div>

  <div class="tabs">
    <button class="tab active" onclick="switchTab('agents',this)">agents</button>
    <button class="tab" onclick="switchTab('trades',this)">trades</button>
    <button class="tab" onclick="switchTab('apis',this)">api keys</button>
    <button class="tab" onclick="switchTab('settings',this)">settings</button>
    <button class="tab" onclick="switchTab('votes',this)">council log</button>
  </div>

  <!-- AGENTS TAB -->
  <div id="tab-agents" class="panel active">
    <div class="grid2">
      <div class="card">
        <h3>council agents</h3>
        <div id="agent-list"><div class="empty">loading…</div></div>
        <div class="add-row">
          <input id="new-name"   placeholder="name e.g. ALPHA" />
          <input id="new-model"  placeholder="model e.g. groq" />
          <input id="new-weight" type="number" value="1" style="width:48px" />
          <button class="save-btn" onclick="addAgent()">+ add</button>
        </div>
      </div>
      <div class="card">
        <h3>positions</h3>
        <div id="position-list"><div class="empty">loading…</div></div>
      </div>
    </div>
  </div>

  <!-- TRADES TAB -->
  <div id="tab-trades" class="panel">
    <div class="card">
      <h3>recent trades</h3>
      <div id="trade-list"><div class="empty">loading…</div></div>
    </div>
  </div>

  <!-- API KEYS TAB -->
  <div id="tab-apis" class="panel">
    <div class="card">
      <h3>api keys</h3>
      <div id="api-list"><div class="empty">loading…</div></div>
      <p style="margin-top:12px;font-size:11px;color:var(--muted)">
        Keys are saved to your .env file on disk. Never leave this page open publicly.
      </p>
    </div>
  </div>

  <!-- SETTINGS TAB -->
  <div id="tab-settings" class="panel">
    <div class="card">
      <h3>trading config</h3>
      <div id="settings-list"><div class="empty">loading…</div></div>
    </div>
  </div>

  <!-- COUNCIL LOG TAB -->
  <div id="tab-votes" class="panel">
    <div class="card">
      <h3>council vote log</h3>
      <div id="vote-list"><div class="empty">loading…</div></div>
    </div>
  </div>

</div>

<div class="toast" id="toast"></div>

<script>
const API = 'http://localhost:8000';
let botRunning = false;
let state = {};

// ── helpers ───────────────────────────────────────────────────────────────────
async function api(path, opts={}) {
  try {
    const r = await fetch(API + path, { headers:{'Content-Type':'application/json'}, ...opts });
    return r.json();
  } catch(e) {
    return { error: e.message };
  }
}

function toast(msg, dur=2500) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), dur);
}

function switchTab(name, btn) {
  document.querySelectorAll('.panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
  document.getElementById('tab-' + name).classList.add('active');
  if (btn) btn.classList.add('active');
}

function fmtPct(v) {
  v = parseFloat(v||0);
  return (v >= 0 ? '+' : '') + v.toFixed(1) + '%';
}

// ── status + portfolio ────────────────────────────────────────────────────────
async function refreshStatus() {
  const s = await api('/status');
  if (s.error) return;
  botRunning = s.running;
  const badge = document.getElementById('bot-badge');
  const btn   = document.getElementById('bot-btn');
  badge.textContent = s.running ? 'running' : 'stopped';
  badge.className   = 'badge ' + (s.running ? 'on' : 'off');
  btn.textContent   = s.running ? 'stop bot' : 'start bot';
  btn.className     = 'btn ' + (s.running ? 'danger' : 'primary');

  const fgv = s.fear_greed || 50;
  document.getElementById('fg-fill').style.width = fgv + '%';
  const fgLabel = document.getElementById('fg-label');
  fgLabel.textContent = fgv + ' — ' + (s.fg_label || 'Neutral');
  fgLabel.style.color = fgv < 30 ? 'var(--red)' : fgv > 70 ? 'var(--green)' : 'var(--yellow)';
}

async function refreshPortfolio() {
  const p = await api('/portfolio');
  if (p.error) return;
  state.portfolio = p;

  const mPnl = document.getElementById('m-pnl');
  mPnl.textContent = '$' + (p.realized_pnl >= 0 ? '+' : '') + p.realized_pnl.toFixed(2);
  mPnl.className = 'value ' + (p.realized_pnl >= 0 ? 'green' : 'red');

  document.getElementById('m-portfolio').textContent = '$' + p.portfolio.toFixed(2);
  document.getElementById('m-winrate').textContent = p.win_rate + '%';
  document.getElementById('m-positions').textContent = p.positions.length;

  // positions list
  const el = document.getElementById('position-list');
  if (!p.positions.length) { el.innerHTML = '<div class="empty">no open positions</div>'; return; }
  el.innerHTML = p.positions.map(pos => {
    const pct = parseFloat(pos.pnl_pct || 0);
    const cls = pct >= 0 ? 'green' : 'red';
    return `<div class="trade-row">
      <div class="dot ${cls}"></div>
      <span style="font-weight:600;min-width:60px">${pos.token}</span>
      <span style="color:var(--muted);flex:1">@ $${parseFloat(pos.entry_price||0).toFixed(6)}</span>
      <span class="pnl ${pct>=0?'pos':'neg'}">${fmtPct(pct)}</span>
    </div>`;
  }).join('');
}

// ── agents ────────────────────────────────────────────────────────────────────
async function refreshAgents() {
  const data = await api('/agents');
  if (data.error || !data.agents) return;
  state.agents = data.agents;

  const el = document.getElementById('agent-list');
  el.innerHTML = data.agents.map(a => `
    <div class="agent-row">
      <div class="dot green"></div>
      <div class="agent-name">${a.name}</div>
      <div class="agent-model">${a.model} — ${a.role}</div>
      <div class="agent-weight">w=${a.weight}</div>
      <button class="btn" style="padding:3px 8px;font-size:10px" onclick="removeAgent('${a.id}')">×</button>
    </div>`).join('');
}

async function addAgent() {
  const name   = document.getElementById('new-name').value.trim();
  const model  = document.getElementById('new-model').value.trim();
  const weight = parseInt(document.getElementById('new-weight').value) || 1;
  if (!name || !model) { toast('need name + model'); return; }
  const res = await api('/agents', {
    method:'POST',
    body: JSON.stringify({ id: name.toLowerCase(), name: name.toUpperCase(), model, weight })
  });
  if (res.ok) { toast('agent added ✓'); refreshAgents(); }
  else toast('error: ' + (res.detail || 'failed'));
}

async function removeAgent(id) {
  if (!confirm('Remove ' + id + '?')) return;
  const res = await api('/agents/' + id, { method:'DELETE' });
  if (res.ok) { toast('agent removed'); refreshAgents(); }
  else toast('error: ' + (res.detail || 'cannot remove'));
}

// ── trades ────────────────────────────────────────────────────────────────────
async function refreshTrades() {
  const trades = await api('/trades');
  const el = document.getElementById('trade-list');
  if (!trades.length) { el.innerHTML = '<div class="empty">no trades yet</div>'; return; }
  el.innerHTML = trades.map(t => {
    const pct = parseFloat(t.pnl_pct || 0);
    const ts  = (t.ts || '').slice(11, 16);
    return `<div class="trade-row">
      <span class="side ${t.action==='BUY'?'buy':'sell'}">${t.action}</span>
      <span style="min-width:64px;font-weight:600">${t.token}</span>
      <span style="color:var(--muted);flex:1">@ $${parseFloat(t.price||0).toFixed(6)}</span>
      <span class="pnl ${pct>=0?'pos':'neg'}">${pct?fmtPct(pct):''}</span>
      <span style="color:var(--muted);font-size:10px">${ts}</span>
    </div>`;
  }).join('');
}

// ── api keys ──────────────────────────────────────────────────────────────────
async function refreshKeys() {
  const keys = await api('/keys');
  const el   = document.getElementById('api-list');
  if (keys.error) { el.innerHTML = '<div class="empty">API server offline</div>'; return; }

  el.innerHTML = Object.entries(keys).map(([k, info]) => `
    <div class="api-row">
      <div class="api-name">${k.replace('_API_KEY','').replace('_TOKEN','').replace('_',' ').toLowerCase()}</div>
      <input class="api-input" id="key-${k}" type="password"
        placeholder="${info.set ? info.preview : 'paste key here'}"
        value="${info.set ? '••••••••' : ''}" />
      <span class="status-pill ${info.set?'ok':'fail'}">${info.set?'ok':'not set'}</span>
      <button class="save-btn" onclick="saveKey('${k}')">save</button>
    </div>`).join('');
}

async function saveKey(k) {
  const el  = document.getElementById('key-' + k);
  const val = el.value.trim();
  if (!val || val === '••••••••') { toast('paste the actual key'); return; }
  const res = await api('/keys', { method:'POST', body: JSON.stringify({ key: k, value: val }) });
  if (res.ok) { toast(k + ' saved ✓'); refreshKeys(); }
  else toast('failed: ' + (res.detail || 'error'));
}

// ── settings ──────────────────────────────────────────────────────────────────
let settingsCache = {};

async function refreshSettings() {
  const s = await api('/settings');
  if (s.error) return;
  settingsCache = s;
  const el = document.getElementById('settings-list');
  const rows = [
    { key:'paper_trading',    label:'Paper trading',    sub:'no real money',           type:'toggle' },
    { key:'vote_threshold',   label:'Vote threshold',   sub:'min weighted % to trade', type:'pct'    },
    { key:'min_agents_trade', label:'Min agents',       sub:'council quorum',          type:'num'    },
    { key:'take_profit_pct',  label:'Take profit',      sub:'auto sell target',        type:'pct'    },
    { key:'stop_loss_pct',    label:'Stop loss',        sub:'auto sell floor',         type:'pct_neg'},
    { key:'max_position_pct', label:'Max position',     sub:'% of portfolio per trade',type:'pct'    },
  ];
  el.innerHTML = rows.map(r => {
    const v = s[r.key];
    let ctrl = '';
    if (r.type === 'toggle') {
      ctrl = `<div class="toggle ${v?'on':''}" onclick="toggleSetting('${r.key}', this)"></div>`;
    } else {
      const display = r.type==='pct' ? Math.round((v||0)*100)+'%'
                    : r.type==='pct_neg' ? (v<0?'':'-')+Math.abs(Math.round((v||0)*100))+'%'
                    : v;
      ctrl = `<div class="setting-val" onclick="editSetting('${r.key}','${r.type}')" style="cursor:pointer;color:var(--blue)">${display}</div>`;
    }
    return `<div class="setting-row">
      <div class="setting-label">${r.label}<small>${r.sub}</small></div>
      ${ctrl}
    </div>`;
  }).join('');
}

async function toggleSetting(key, el) {
  const cur = settingsCache[key];
  const patch = {}; patch[key] = !cur;
  const res = await api('/settings', { method:'PATCH', body: JSON.stringify(patch) });
  if (res.ok) { settingsCache[key] = !cur; el.classList.toggle('on'); toast(key + ' updated ✓'); }
}

async function editSetting(key, type) {
  const cur = settingsCache[key];
  const disp = type==='pct'||type==='pct_neg' ? Math.round((cur||0)*100) : cur;
  const val  = prompt(`${key} (current: ${disp})`, disp);
  if (val === null) return;
  let v = parseFloat(val);
  if (isNaN(v)) { toast('invalid number'); return; }
  if (type==='pct' || type==='pct_neg') v = v / 100;
  const patch = {}; patch[key] = v;
  const res = await api('/settings', { method:'PATCH', body: JSON.stringify(patch) });
  if (res.ok) { settingsCache[key] = v; toast(key + ' updated ✓'); refreshSettings(); }
}

// ── council log ───────────────────────────────────────────────────────────────
async function refreshVotes() {
  const votes = await api('/votes');
  const el = document.getElementById('vote-list');
  if (!votes.length) { el.innerHTML = '<div class="empty">no votes yet</div>'; return; }
  el.innerHTML = votes.map(v => {
    const dec = v.decision || 'PASS';
    const col = dec==='TRADE' ? 'var(--green)' : dec==='HOLD' ? 'var(--yellow)' : 'var(--muted)';
    return `<div class="trade-row" style="font-size:11px">
      <span style="min-width:70px;font-weight:600;color:var(--blue)">${v.token}</span>
      <span style="min-width:60px;color:var(--muted)">${v.agent}</span>
      <span style="min-width:48px;font-weight:700;color:${col}">${dec}</span>
      <span style="color:var(--muted);flex:1">${v.confidence}% conf · w=${v.weight}</span>
      <span style="color:var(--muted)">${(v.ts||'').slice(11,16)}</span>
    </div>`;
  }).join('');
}

// ── bot control ───────────────────────────────────────────────────────────────
async function toggleBot() {
  const endpoint = botRunning ? '/bot/stop' : '/bot/start';
  const res = await api(endpoint, { method:'POST' });
  toast(res.msg || (res.ok ? 'done' : 'failed'));
  setTimeout(refreshStatus, 800);
}

// ── init ──────────────────────────────────────────────────────────────────────
async function refreshAll() {
  await Promise.all([
    refreshStatus(),
    refreshPortfolio(),
    refreshAgents(),
    refreshTrades(),
    refreshKeys(),
    refreshSettings(),
    refreshVotes(),
  ]);
}

refreshAll();
setInterval(refreshAll, 30000); // auto-refresh every 30s
</script>
</body>
</html>
